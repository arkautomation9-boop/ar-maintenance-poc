{
    "appId": "com.armaintenance.poc",
    "appName": "AR Maintenance",
    "webDir": "www",
    "bundledWebRuntime": false,
    "server": {
        "androidScheme": "http",
        "cleartext": true
    },
    "plugins": {
        "Camera": {
            "presentationStyle": "fullscreen"
        }
    },
    "android": {
        "allowMixedContent": true,
        "captureInput": true,
        "webContentsDebuggingEnabled": true
    }
}